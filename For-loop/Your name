#include <stdio.h>

int main() {
    char name[50]; // Space for a name up to 49 characters
    int count;

    printf("Enter your name: ");
    scanf("%s", name); // Takes the name from the user

    printf("How many times should I repeat it? ");
    scanf("%d", &count);

    // The For Loop
    for (int i = 1; i <= count; i++) {
        printf("%d. Hello, %s!\n", i, name);
    }

    return 0;
}
